# Database (Neon)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Better Auth
BETTER_AUTH_SECRET="your-secret-here-min-32-chars"
BETTER_AUTH_URL="http://localhost:3000"

# App URL (set per-app in apps/*/env.local if needed)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# App URLs (used by app switcher and cross-app navigation)
NEXT_PUBLIC_NOTES_URL="http://localhost:3005"
NEXT_PUBLIC_JOURNALER_URL="http://localhost:3006"

# Resend (email verification)
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="no-reply@yourdomain.com"
